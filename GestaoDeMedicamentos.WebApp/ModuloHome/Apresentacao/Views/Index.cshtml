@{
    Layout = "_Layout";
    ViewBag.Titulo = "Página Inicial";
}

<div class="row">
    <div class="col-lg-7">
        <h1 class="display-5 fw-semibold mb-3">Controle de Medicamentos TK'S</h1>
        <p class="lead text-secondary mb-4">
            Gestão de Medicamentos para o melhor Controle de Entrada e Saída do Estoque!
        </p>

        <a class="btn btn-primary rounded-pill px-4" asp-controller="Categoria" asp-action="Listar">Acessar
            Fornecedores</a>
        </div>

        <div class="col-lg-5">
            <div class="card border-primary-subtle shadow-sm">
                <div class="card-body p-4">
                    <h3 class="h5 text-primary mb-3">Módulos disponíveis</h3>

                    <div class="list-group">
                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                           asp-controller="Fornecedor" asp-action="Listar">
                            Acessar Fornecedores
                            <span class="badge text-bg-primary rounded-pill">Abrir</span>
                        </a>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
