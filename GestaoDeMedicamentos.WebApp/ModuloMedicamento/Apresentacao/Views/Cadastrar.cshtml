@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastrar Medicamento";

    List<ListarFornecedorViewModel> Fornecedores = ViewBag.Fornecedores;
}
@model CadastrarMedicamentoViewModel;

<body>
    <form class="card border border-secondary shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Cadastrar"
          method="post">
        <div class="">
            <label asp-for="Nome" class="form-label fw-semibold text-uppercase small mt-3 fs-4">Nome</label>
            <input asp-for="Nome" type="text" class="form-control fs-5">
            <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
        </div>
        <div class="">
            <label asp-for="Descricao" class="form-label fw-semibold text-uppercase small mt-3 fs-4">Descriçao</label>
            <input asp-for="Descricao" type="text" class="form-control fs-5">
            <span asp-validation-for="Descricao" class="text-danger small fw-semibold"></span>
        </div>
        <div class="">
            <label asp-for="QuantidadeEstoque" class="form-label fw-semibold text-uppercase small mt-3 fs-4">Quantidade
            </label>
            <input asp-for="QuantidadeEstoque" type="number" min="1" class="form-control fs-5">
            <span asp-validation-for="QuantidadeEstoque" class="text-danger small fw-semibold"></span>
        </div>
        <div class="mb-3 d-flex flex-column">
            <label asp-for="Fornecedor" class="form-label fw-semibold text-uppercase small mt-3 fs-4">Fornecedor</label>
            <select asp-for="Fornecedor" class="form-control fs-5">
                <option value="">Selecione uma Fornecedor</option>
                @foreach (ListarFornecedorViewModel fornecedor in Fornecedores)
                {
                    <option value="@fornecedor.Id">
                        @fornecedor.Nome
                    </option>
                }
            </select>
            <span asp-validation-for="Fornecedor" class="text-danger small fw-semibold"></span>
        </div>
        <div class=" d-flex justify-content-end gap-2 mt-4">
            <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
            <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
        </div>
    </form>
</body>